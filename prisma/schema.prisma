generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkItemStatus {
  BACKLOG
  PLANNED
  IN_PROGRESS
  BLOCKED
  DONE
  SKIPPED
}

enum ApplicationStatus {
  INTERESTED
  PREPARING
  APPLIED
  CODING_TEST
  INTERVIEW
  OFFER
  REJECTED
  ARCHIVED
}

enum StudyStatus {
  BACKLOG
  PLANNED
  IN_PROGRESS
  REVIEWING
  DONE
}

enum ProjectStatus {
  IDEA
  ACTIVE
  BLOCKED
  POLISHING
  READY
  ARCHIVED
}

enum AssistantMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AssistantActionType {
  CREATE_CALENDAR_EVENT
  DELETE_CALENDAR_EVENT
}

enum AssistantActionStatus {
  PROPOSED
  APPROVED
  APPLIED
  REJECTED
  FAILED
}

enum CalendarLinkStatus {
  ACTIVE
  DELETED
}

model Sprint {
  id        String     @id @default(cuid())
  name      String
  goal      String
  startsOn  DateTime
  endsOn    DateTime
  isActive  Boolean    @default(false)
  capacity  Int?
  review    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  workItems WorkItem[]

  @@index([isActive])
  @@index([startsOn, endsOn])
}

model WorkItem {
  id          String         @id @default(cuid())
  sprintId    String?
  title       String
  description String?
  status      WorkItemStatus @default(BACKLOG)
  area        String
  dueDate     DateTime?
  estimate    Int?
  priority    Int            @default(2)
  blocker     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  sprint      Sprint?        @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  @@index([sprintId, status])
  @@index([dueDate])
  @@index([area])
}

model JobApplication {
  id              String            @id @default(cuid())
  company         String
  role            String
  postingUrl      String?
  deadline        DateTime?
  status          ApplicationStatus @default(INTERESTED)
  resumeVersionId String?
  nextAction      String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  resumeVersion   ResumeVersion?    @relation(fields: [resumeVersionId], references: [id], onDelete: SetNull)

  @@index([deadline])
  @@index([status])
}

model ResumeVersion {
  id           String           @id @default(cuid())
  name         String
  targetRole   String?
  changeNotes  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  applications JobApplication[]
}

model StudyItem {
  id             String      @id @default(cuid())
  topic          String
  resource       String?
  targetDate     DateTime?
  estimatedHours Int?
  progress       Int         @default(0)
  status         StudyStatus @default(BACKLOG)
  reviewDate     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([targetDate])
  @@index([status])
}

model PortfolioProject {
  id             String        @id @default(cuid())
  name           String
  goal           String
  stack          String?
  status         ProjectStatus @default(IDEA)
  nextAction     String?
  hasReadme      Boolean       @default(false)
  hasDemo        Boolean       @default(false)
  hasDeployment  Boolean       @default(false)
  hasTests       Boolean       @default(false)
  portfolioReady Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
  @@index([portfolioReady])
}

model AssistantConversation {
  id             String             @id @default(cuid())
  title          String
  codexSessionId String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  messages       AssistantMessage[]
  actions        AssistantAction[]
}

model AssistantMessage {
  id             String                @id @default(cuid())
  conversationId String
  role           AssistantMessageRole
  content        String
  createdAt      DateTime              @default(now())
  conversation   AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model AssistantAction {
  id              String                @id @default(cuid())
  conversationId  String
  type            AssistantActionType
  status          AssistantActionStatus @default(PROPOSED)
  summary         String?
  description     String?
  startDateTime   DateTime?
  endDateTime     DateTime?
  timeZone        String?
  sourceType      String?
  sourceId        String?
  provider        String?
  calendarId      String?
  externalEventId String?
  payload         Json?
  result          Json?
  error           String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  conversation    AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, status])
  @@index([type, status])
  @@index([externalEventId])
}

model CalendarEventLink {
  id              String             @id @default(cuid())
  provider        String
  calendarId      String
  externalEventId String
  sourceType      String?
  sourceId        String?
  summary         String
  startDateTime   DateTime
  endDateTime     DateTime
  status          CalendarLinkStatus @default(ACTIVE)
  actionId        String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([provider, calendarId, externalEventId])
  @@index([sourceType, sourceId])
  @@index([status])
}
